{
  "name": "rms-next",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/prep-next-dev.cjs && next dev",
    "clean": "rm -rf .next .next-dev node_modules/.cache",
    "dev:clean": "npm run clean && node scripts/prep-next-dev.cjs && next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx scripts/run-migrations.ts",
    "db:baseline-migrations": "tsx scripts/baseline-drizzle-migrations.ts",
    "db:push": "drizzle-kit push",
    "db:check": "npm run db:generate && git diff --exit-code",
    "db:studio": "drizzle-kit studio",
    "worker:process-event": "tsx src/lib/queue/workers/process-event-worker.ts",
    "worker:bulk-import": "tsx src/lib/queue/workers/process-bulk-import-worker.ts",
    "worker:resume-structure": "tsx src/lib/queue/workers/process-resume-structure-worker.ts",
    "worker:notification-delivery": "tsx src/lib/queue/workers/process-notification-delivery-worker.ts",
    "worker:lifecycle-reminders": "tsx src/lib/queue/workers/process-lifecycle-reminders-worker.ts",
    "verify:phase4-contract": "tsx src/scripts/verify-phase4-contract.ts",
    "test:e2e": "playwright test",
    "test:unit": "node --test --import tsx tests/unit/*.test.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1031.0",
    "@tanstack/react-query": "^5.99.0",
    "axios": "^1.15.0",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.74.1",
    "drizzle-orm": "^0.45.2",
    "ioredis": "^5.10.1",
    "jose": "^6.2.2",
    "lucide-react": "^1.8.0",
    "mammoth": "^1.12.0",
    "next": "14.2.18",
    "nodemailer": "^8.0.6",
    "pdf-parse": "^1.1.4",
    "pdfkit": "^0.18.0",
    "postgres": "^3.4.9",
    "react": "^18",
    "react-dom": "^18",
    "sonner": "^2.0.7",
    "word-extractor": "^1.0.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/nodemailer": "^8.0.0",
    "@types/pdfkit": "^0.17.5",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "drizzle-kit": "^0.31.10",
    "eslint": "^8",
    "eslint-config-next": "14.2.18",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
