# --- Browser (existing SPA / Next client → API) ---
# Point at this Next app to use migrated routes (auth + Phase 2 reference data).
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:3000/api

# --- Server-only: Next.js auth + Drizzle (Phase 1+) ---
# Same PostgreSQL database as FastAPI / Alembic.
DATABASE_URL=postgresql://USER:PASSWORD@127.0.0.1:5432/rfm

# Must match backend `.env` if tokens should be interchangeable during cutover.
JWT_SECRET_KEY=
# Optional fallback name (matches FastAPI `utils/jwt.py`)
# SECRET_KEY=

JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=14

# Protect internal workflow endpoints (/api/workflow/health, /api/workflow/metrics/prometheus).
# Required in production (requests must send `Authorization: Bearer <token>`).
METRICS_BEARER_TOKEN=

# Audit export safety caps
AUDIT_EXPORT_MAX_DAYS=31
AUDIT_EXPORT_MAX_ROWS=5000

# JD PDF storage for Phase D requisition routes (mirrors FastAPI `STORAGE_LOCAL_DIR` / `storage/jd`).
# STORAGE_LOCAL_DIR=
