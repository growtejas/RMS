# --- Browser (existing SPA / Next client → API) ---
# Point at this Next app to use migrated routes (auth + Phase 2 reference data).
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:3000/api

# --- Server-only: Next.js auth + Drizzle (Phase 1+) ---
# Same PostgreSQL database as FastAPI / Alembic.
DATABASE_URL=postgresql://USER:PASSWORD@127.0.0.1:5432/rfm

# Queue / workers (Phase 2)
REDIS_URL=redis://127.0.0.1:6379

# Public apply / inbound persist: fallback `requisition_items.item_id` when job slug is not numeric (optional).
# PUBLIC_APPLY_DEFAULT_REQUISITION_ITEM_ID=1

# Must match backend `.env` if tokens should be interchangeable during cutover.
JWT_SECRET_KEY=
# Optional fallback name (matches FastAPI `utils/jwt.py`)
# SECRET_KEY=

JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=14

# Google OAuth login + Calendar Meet generation
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# Optional; default already includes calendar.events:
# GOOGLE_OAUTH_SCOPES=openid email profile https://www.googleapis.com/auth/calendar.events
# Enable Calendar/Meet auto-link:
# GOOGLE_CALENDAR_SYNC_ENABLED=true

# Protect internal workflow endpoints (/api/workflow/health, /api/workflow/metrics/prometheus).
# Required in production (requests must send `Authorization: Bearer <token>`).
METRICS_BEARER_TOKEN=

# Dev only (ignored in production): skip CSRF double-submit checks on mutating /api/* when cookie
# session is used without x-csrf-token (e.g. Postman). Prefer Authorization: Bearer <jwt> instead.
# API_CSRF_DISABLE=true

# Audit export safety caps
AUDIT_EXPORT_MAX_DAYS=31
AUDIT_EXPORT_MAX_ROWS=5000

# JD PDF storage for Phase D requisition routes (mirrors FastAPI `STORAGE_LOCAL_DIR` / `storage/jd`).
# STORAGE_LOCAL_DIR=

# Phase 5 ranking weights (0-1 or percentage values like 55/45).
RANKING_KEYWORD_WEIGHT=0.40
RANKING_SEMANTIC_WEIGHT=0.25
RANKING_BUSINESS_WEIGHT=0.35

# Ranking engine mode:
# - ai_only: final_score uses cached AI score when available; deterministic score is fallback only
# - hybrid: final_score blends cached AI score with deterministic score
# - deterministic: final_score uses deterministic scoring only (Phase 5 + ATS V1 + skill gate)
# Back-compat: ats_v1 | phase5_only still work as deterministic sub-modes.
RANKING_ENGINE=ai_only
RANKING_ATS_V1_WEIGHT=0.35

# ATS quality buckets (0–100 final score lower bounds; see src/lib/services/ats-buckets.ts)
# ATS_BUCKET_BEST_MIN=85
# ATS_BUCKET_VERY_GOOD_MIN=70
# ATS_BUCKET_GOOD_MIN=55
# ATS_BUCKET_AVERAGE_MIN=35

# When true, GET /api/ranking/requisition-items/[itemId] returns 424 if no valid snapshot (no auto-recompute).
# RANKING_STRICT_SNAPSHOT_READ=false

# Ranking: require at least one derived required skill (JSON, Primary/Secondary, or JD token fallback).
# Set to true only for legacy items with no JD/skills text.
RANKING_ALLOW_EMPTY_REQUIRED_SKILLS=false

# Candidate resume: reject create when same resume hash already exists on the requisition line (409).
# Default is flag-only (duplicate_resume_of_candidate_id) unless this is true.
# CANDIDATE_RESUME_HASH_REJECT_DUPLICATES=false

# Phase 5 local embedding vector settings (semantic ranking cache).
EMBEDDING_VECTOR_DIM=256

# --- Structured resume (versioned JSON on candidates.resume_structured_profile) ---
# Master switch: rules-based v2 extraction on ingest, ranking backfill, and manual create.
RESUME_STRUCTURE_ENABLED=true
# Recompute even when source_hash matches (debug).
# RESUME_STRUCTURE_FORCE_REBUILD=false
# Max plain-text chars fed to rules extractor / LLM.
# RESUME_STRUCTURE_MAX_TEXT_CHARS=14000

# Async LLM refinement (enqueue job; run worker: `npm run worker:resume-structure`).
# If LLM is enabled but LLM_SYNC=false, the LLM is NOT called during candidate create — only the worker calls it.
# If LLM_ENABLED + LLM_SYNC are true but the rules extractor confidence is high, the LLM is skipped unless:
# RESUME_STRUCTURE_LLM_ALWAYS=true
# RESUME_STRUCTURE_LLM_ENABLED=false
# RESUME_STRUCTURE_LLM_SYNC=false
# If overall confidence is below this (0–1), suggest refinement / enqueue async job.
# RESUME_STRUCTURE_LLM_CONFIDENCE_THRESHOLD=0.45
# RESUME_STRUCTURE_LLM_TIMEOUT_MS=28000
# RESUME_STRUCTURE_LLM_MAX_INPUT_CHARS=14000

# OpenAI-compatible API (optional). Same vars work with Groq, e.g.:
#   RESUME_STRUCTURE_OPENAI_BASE_URL=https://api.groq.com/openai/v1
#   RESUME_STRUCTURE_OPENAI_API_KEY=gsk_...
#   RESUME_STRUCTURE_OPENAI_MODEL=llama-3.3-70b-versatile
# RESUME_STRUCTURE_OPENAI_API_KEY=
# RESUME_STRUCTURE_OPENAI_BASE_URL=https://api.openai.com/v1
# RESUME_STRUCTURE_OPENAI_MODEL=gpt-4o-mini

# --- Optional AI evaluation layer (ranking secondary signal; see docs/AI_EVALUATION_LAYER.md) ---
# Master switch for POST /api/ranking/requisition-items/[itemId]/ai-evaluation (GET ?ai_eval=1 only reads DB cache).
# AI_EVAL_ENABLED=false
# LLM backend: gemini | groq
# AI_EVAL_LLM_PROVIDER=gemini
# Google Gemini (AI Studio key; free tier available): https://aistudio.google.com/apikey
# Google Gemini (AI Studio key; free tier available): https://aistudio.google.com/apikey
# AI_EVAL_GEMINI_API_KEY=
# AI_EVAL_GEMINI_MODEL=gemini-2.5-flash
# AI_EVAL_GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
#
# Groq (OpenAI-compatible API):
# AI_EVAL_LLM_PROVIDER=groq
# AI_EVAL_GROQ_API_KEY=
# AI_EVAL_GROQ_BASE_URL=https://api.groq.com/openai/v1
# AI_EVAL_GROQ_MODEL=llama-3.1-8b-instant
# AI_EVAL_TIMEOUT_MS=45000
# AI_EVAL_MAX_INPUT_CHARS=16000
# Bump when prompt instructions change (invalidates cache lookups vs new hashes).
# AI_EVAL_PROMPT_VERSION=ai-eval-v1
# Pause between candidates when POST evaluates many rows (reduces OpenAI 429 bursts). Default 1500.
# AI_EVAL_MIN_INTERVAL_MS=1500
# Max extra attempts after HTTP 429 per candidate (honors Retry-After when present). Default 3.
# AI_EVAL_429_MAX_RETRIES=3
# Return immediately on first 429 (no backoff). Use when Postman/UI “hangs” on rate limits.
# AI_EVAL_429_FAIL_FAST=true
# Max wait from Retry-After / backoff cap (ms). Default 90000.
# AI_EVAL_429_BACKOFF_CAP_MS=90000

# --- Outbound email (Shortlist, interviews, offers) ---
# Without SMTP (or a webhook), emails are only printed in the server terminal (not delivered to inboxes).
# LIFECYCLE_NOTIFICATIONS=0 disables queuing all lifecycle emails.
#
# Real inbox using SMTP (Gmail, Microsoft 365, or your org relay) — at minimum set host + auth:
# EMAIL_TRANSPORT=smtp
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@gmail.com
# SMTP_PASS=abcdefghijklmnop
#   (16-char *App password*; 2-Step must be on. Spaces in the generated password are ok — we strip them.
#   Or use single-quoted: SMTP_PASS='xxxx xxxx xxxx xxxx')
# EMAIL_FROM=you@gmail.com
# Optional display name: SMTP_FROM_NAME=Acme Recruiting
# Port 465 with SSL: SMTP_SECURE=true, SMTP_PORT=465
#
# Or: EMAIL_TRANSPORT=webhook and EMAIL_WEBHOOK_URL=https://... (JSON body: to, from, subject, text, tags)

